# ── Retena Multi-Tenant Mode ──────────────────────────────────────────────────
# Set RETENA_MODE=true to enable Supabase auth + Retena message capture

RETENA_MODE=true

# ── Supabase (Retena project) ─────────────────────────────────────────────────
SUPABASE_URL=https://mfhdoiddbgpjqjukacnc.supabase.co
SUPABASE_KEY=<anon key>
SUPABASE_SERVICE_KEY=<service role key>

# ── Groq (Whisper transcription) ──────────────────────────────────────────────
GROQ_API_KEY=<your groq key>

# ── Retena API auth (for /api/retena/* endpoints) ────────────────────────────
RETENA_API_KEY=<generate a random secret>

# ── Optional per-deployment config ───────────────────────────────────────────
AUTO_TRANSCRIBE=true       # Set to false to capture only, no transcription
OWNER_MODE=false           # true = mirror all transcriptions to OWNER_NUMBER DM
OWNER_NUMBER=18091234567   # Required if OWNER_MODE=true

# ── Super-Light required vars ─────────────────────────────────────────────────
PORT=3000
TOKEN_ENCRYPTION_KEY=<64-char hex — node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">
ADMIN_DASHBOARD_PASSWORD=<your admin password>
SESSION_SECRET=<random secret>
NODE_ENV=production
